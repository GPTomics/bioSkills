// RAPTOR / MedCMU-HPC Nextflow profile for Slurm + Apptainer.
// Set RAPTOR_PARTITION, PROJECT_DIR, and SCRATCH_DIR in the launch environment before production use.

params {
  raptor_partition = System.getenv('RAPTOR_PARTITION') ?: '<PARTITION>'
  project_dir = System.getenv('PROJECT_DIR') ?: '<PROJECT_DIR>'
  scratch_dir = System.getenv('SCRATCH_DIR') ?: '<SCRATCH_DIR>'
  outdir = System.getenv('OUTDIR') ?: "${params.project_dir}/results/rnaseq"
  work_dir = System.getenv('WORKDIR') ?: "${params.scratch_dir}/nextflow-work/rnaseq"
  apptainer_cache = System.getenv('APPTAINER_CACHEDIR') ?: "${params.scratch_dir}/apptainer-cache"
  apptainer_tmp = System.getenv('APPTAINER_TMPDIR') ?: "${params.scratch_dir}/apptainer-tmp"
}

workDir = params.work_dir

process {
  executor = 'slurm'
  queue = params.raptor_partition
  scratch = false

  errorStrategy = { task.exitStatus in [104, 137, 139, 140, 143] ? 'retry' : 'terminate' }
  maxRetries = 2

  withLabel: process_low {
    cpus = 2
    memory = '8 GB'
    time = '2h'
  }

  withLabel: process_medium {
    cpus = 8
    memory = '32 GB'
    time = '12h'
  }

  withLabel: process_high {
    cpus = 16
    memory = '96 GB'
    time = '48h'
  }
}

executor {
  queueSize = 4
  submitRateLimit = '30 sec'
}

apptainer {
  enabled = true
  autoMounts = true
  cacheDir = params.apptainer_cache
}

singularity {
  enabled = false
}

env {
  APPTAINER_CACHEDIR = params.apptainer_cache
  APPTAINER_TMPDIR = params.apptainer_tmp
}

timeline {
  enabled = true
}

report {
  enabled = true
}

trace {
  enabled = true
}

dag {
  enabled = true
}
