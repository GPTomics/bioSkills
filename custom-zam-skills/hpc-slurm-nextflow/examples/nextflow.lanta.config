// LANTA Nextflow profile for Slurm + Apptainer.
// Set PROJECT_ID and LANTA_ACCOUNT in the launch environment before production use.

params {
  project_id = System.getenv('PROJECT_ID') ?: '<PROJECT_ID-SHORTNAME>'
  lanta_account = System.getenv('LANTA_ACCOUNT') ?: '<LANTA_ACCOUNT>'
  lanta_user = System.getenv('USER') ?: '<USER>'
  outdir = System.getenv('OUTDIR') ?: "/project/${params.project_id}/results/rnaseq"
  work_dir = System.getenv('WORKDIR') ?: "/scratch/${params.project_id}/${params.lanta_user}/nextflow-work/rnaseq"
  apptainer_cache = System.getenv('APPTAINER_CACHEDIR') ?: "/scratch/${params.project_id}/${params.lanta_user}/apptainer-cache"
  apptainer_tmp = System.getenv('APPTAINER_TMPDIR') ?: "/scratch/${params.project_id}/${params.lanta_user}/apptainer-tmp"
}

workDir = params.work_dir

process {
  executor = 'slurm'
  queue = 'compute'
  clusterOptions = "-A ${params.lanta_account}"
  scratch = false

  errorStrategy = { task.exitStatus in [104, 137, 139, 140, 143] ? 'retry' : 'terminate' }
  maxRetries = 2

  withLabel: process_low {
    cpus = 2
    memory = '8 GB'
    time = '2h'
  }

  withLabel: process_medium {
    cpus = 8
    memory = '32 GB'
    time = '12h'
  }

  withLabel: process_high {
    cpus = 16
    memory = '96 GB'
    time = '48h'
  }
}

executor {
  queueSize = 50
  submitRateLimit = '10 sec'
}

apptainer {
  enabled = true
  autoMounts = true
  cacheDir = params.apptainer_cache
  runOptions = '-B /project:/project -B /scratch:/scratch'
}

singularity {
  enabled = false
}

env {
  APPTAINER_CACHEDIR = params.apptainer_cache
  APPTAINER_TMPDIR = params.apptainer_tmp
}

timeline {
  enabled = true
}

report {
  enabled = true
}

trace {
  enabled = true
}

dag {
  enabled = true
}
